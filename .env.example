# ZestLearn Environment Variables

# Convex
NEXT_PUBLIC_CONVEX_URL=                  # Your Convex deployment URL
CONVEX_DEPLOYMENT=                        # Your Convex deployment name

# AI Providers
OPENAI_API_KEY=                          # OpenAI API key for report generation (gpt-4o-mini)
GEMINI_API_KEY=                          # Google Gemini API key for document/chat features that still use Gemini
FEATHERLESS_API_KEY=                     # Featherless.ai API key (optional fallback)

# Automation
N8N_WEBHOOK_URL=                         # n8n webhook endpoint for notifications

# Optional
ELEVENLABS_API_KEY=                      # ElevenLabs API key for voice narration (nice-to-have)
